{
  "name": "multi-bot-open-branches",
  "enforcement": "enabled",
  "target": {
    "branch_patterns": [
      "bot-*",
      "copilot/*"
    ]
  },
  "bypass_actors": [],
  "rules": {
    "block_force_pushes": true,
    "block_deletions": false,
    "restrict_creation": false,
    "restrict_updates": false,
    "require_pull_request": false,
    "require_status_checks": [],
    "require_signed_commits": false,
    "require_linear_history": false,
    "require_deployments": [],
    "require_code_scanning": false,
    "require_code_quality": false,
    "copilot_code_review": false
  }
}
