__pycache__/
*.py[cod]
*.pyo

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── OS junk files ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
